{
  "manifest_version": 3,
  "name": "Gemini Chat Folders",
  "version": "1.0.0",
  "description": "Organize your Gemini chats into folders with drag & drop, nested folders, colors, and search.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
